# ── Telegram API ────────────────────────────────────────────────────────────
# Create an app at https://my.telegram.org → API Development Tools
API_ID=12345678
API_HASH=0123456789abcdef0123456789abcdef

# ── Bot token ────────────────────────────────────────────────────────────────
# Get from @BotFather → /newbot
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# ── Your account ─────────────────────────────────────────────────────────────
# The phone number tied to the Telegram account that has joined the channels
# you want to scan.  E.164 format (e.g. +15550001234)
PHONE_NUMBER=+15550001234

# ── Access control ───────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs that may issue bot commands.
# Leave empty to allow anyone who can message the bot.
# Find your ID by messaging @userinfobot
AUTHORIZED_USERS=123456789

# ── Storage ──────────────────────────────────────────────────────────────────
DOWNLOAD_PATH=./downloads
DB_PATH=videos.db
SESSION_NAME=video_scanner

# ── Scan limits ──────────────────────────────────────────────────────────────
# Messages checked per channel/group (0 = no limit — can be very slow)
SCAN_LIMIT=2000

# Maximum video size to download in gigabytes
MAX_FILE_SIZE_GB=8

# Parallel download slots
MAX_CONCURRENT_DOWNLOADS=2
