# ─────────────────────────────────────────────────────────────────────────────
# The Aigency Film Festival — environment
# Everything here is OPTIONAL. With nothing set, the portal runs in DEMO MODE:
# an in-memory store seeded with example films, and submission emails are logged
# to the server console instead of being sent. Add the values below to go live.
# ─────────────────────────────────────────────────────────────────────────────

# ── This edition (change this once per training) ─────────────────────────────
# Public label shown across the site. Reuse the portal for every training by
# editing only this line. Do NOT name a client here unless you want it public.
NEXT_PUBLIC_FESTIVAL_EDITION="Edition I · 2026"

# Public base URL of the deployed site (used to build film-page links in emails).
# e.g. https://festival.ai-gency.ai  — leave blank to auto-detect on Vercel.
NEXT_PUBLIC_SITE_URL=

# ── Admin dashboard ──────────────────────────────────────────────────────────
# The password for /admin. CHANGE THIS before any real training.
ADMIN_PASSWORD="change-me"

# ── Database + poster storage (Supabase — the real backend) ──────────────────
# Create a free project at supabase.com, run supabase/schema.sql in the SQL
# editor, then copy these two values from Project Settings → API.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Public storage bucket name for uploaded posters (created by schema.sql).
SUPABASE_POSTER_BUCKET="posters"

# ── Email on submission (Resend) ─────────────────────────────────────────────
# Create a free key at resend.com. Without a verified domain you can still send
# FROM onboarding@resend.dev TO the account owner's address — perfect for the
# organiser notification.
RESEND_API_KEY=
# Who receives the "new submission" film-page email (you, the organiser).
FESTIVAL_NOTIFY_EMAIL="lab@ai-gency.ai"
# From header. Use onboarding@resend.dev until ai-gency.ai is verified in Resend.
FESTIVAL_FROM_EMAIL="The Aigency Film Festival <onboarding@resend.dev>"
